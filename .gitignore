# ===================================
# GeneAtlas Project .gitignore
# ===================================

# Node.js / Build artifacts
node_modules/
dist/
build/
.next/
out/
*.min.js
*.bundle.js

# Environment variables & secrets
.env
.env.local
.env.production
.env.development
*.key
*.pem
credentials.json

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS generated files
desktop.ini

# Temporary / cache files
tmp/
temp/
.cache/
*.tmp

# Large data files (DNA data, models, etc.)
*.dna
*.fasta
*.fastq
*.vcf
*.bam
*.sam
models/
datasets/
large_files/

# Build outputs
*.zip
*.tar.gz

# Screenshots & heavy media (add selectively)
# /screenshots/*.png
# /mockups/*.psd

# Local development
*.local
*.dev

# Python virtual environments (if backend is added later)
venv/
__pycache__/
*.py[cod]
.pytest_cache/

# Keep these (important for GitHub Pages)
!public/favicon.*
!public/*.svg
!index.html

# Note: Never commit real genomic data
