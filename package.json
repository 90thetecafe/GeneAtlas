{
  "name": "geneatlas",
  "version": "1.0.0",
  "description": "GeneAtlas — Global DNA Intelligence Platform",
  "author": "GeneAtlas Initiative",
  "license": "MIT",
  "homepage": "https://github.com/yourusername/geneatlas",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/geneatlas.git"
  },
  "scripts": {
    "dev": "live-server --open index.html",
