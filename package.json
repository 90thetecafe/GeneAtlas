    "watch": "tailwindcss -i ./src/styles/input.css -o ./dist/output.css --watch",
    "deploy": "gh-pages -d ."
  },
  "devDependencies": {
    "tailwindcss": "^3.4.0",
    "live-server": "^1.2.2",
    "gh-pages": "^6.1.1"
  },
  "keywords": [
    "dna",
    "genomics",
    "bioinformatics",
    "ai",
    "healthcare",
    "geneatlas",
